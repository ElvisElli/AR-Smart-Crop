            {
              "$type": "Models.Manager, Models",
              "CodeArray": [
                "using APSIM.Shared.Utilities;",
                "using Models.Utilities;",
                "using Models.Soils;",
                "using Models.PMF;",
                "using Models.Core;",
                "using System;",
                "",
                "namespace Models",
                "{",
                "    [Serializable] ",
                "    public class Script : Model",
                "    {",
                "    [Link] Clock Clock;",
                "    ",
                "        [Description(\"Crop\")]",
                "        public IPlant Crop { get; set; }",
                "        ",
                "        [Description(\"If the crop is still alive\\nterminate by (d-mmm)\")]",
                "        public string TerminationDate { get; set; }",
                "        ",
                "        [EventSubscribe(\"DoManagement\")]",
                "        private void OnDoManagement(object sender, EventArgs e)",
                "        {",
                "            if (Crop.IsReadyForHarvesting)",
                "            {",
                "                Crop.Harvest();",
                "                Crop.EndCrop();",
                "            }",
                "            ",
                "            if (DateUtilities.WithinDates(TerminationDate, Clock.Today, TerminationDate) && Crop.IsAlive)",
                "            {",
                "                Crop.Harvest();",
                "                Crop.EndCrop();  ",
                "            }",
                "            ",
                "            ",
                "        }",
                "    }",
                "}",
                "       "
              ],
