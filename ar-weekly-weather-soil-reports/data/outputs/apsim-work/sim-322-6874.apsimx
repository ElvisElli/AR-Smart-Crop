              "$type": "Models.Report, Models",
              "VariableNames": [
                "[Clock].Today",
                "[Clock].Today.Year",
                "[Simulation].Name",
                "",
                "//Crop",
                "max of [Soybean].Grain.Wt * 10 from [Soybean].Sowing to [Soybean].Harvesting as Yield_kgha",
                "max of [Soybean].AboveGround.Wt * 10 from [Soybean].Sowing to [Soybean].Harvesting as biomass_kgha",
                "max of [Soybean].LAI from [Soybean].Sowing to [Soybean].Harvesting as Max_LAI",
                "max of [MicroClimate].CanopyCover from [Soybean].Sowing to [Soybean].Harvesting as Max_CanopyCover",
                "",
                "//Soil",
                "sum of [Soil].SoilWater.Drainage from [Clock].StartOfYear to [Clock].EndOfYear as WDrainage",
                "sum of [Soil].SoilWater.Runoff from [Clock].StartOfYear to [Clock].EndOfYear as WRunoff",
                "sum of [Soil].SoilWater.LeachNO3 from [Clock].StartOfYear to [Clock].EndOfYear as NLeaching",
                "sum of sum([Soil].Nutrient.DenitrifiedN) from [Clock].StartOfYear to [Clock].EndOfYear as NDenitrified",
                "mean([Soil].Physical.BD[1:3] as BD_0_30cm",
                "mean([Soil].Physical.SAT[1:3] as SAT_0_30cm",
                "mean([Soil].Physical.DUL[1:3] as DUL_0_30cm",
                "mean([Soil].Physical.LL15[1:3] as LL15_0_30cm",
                "mean([Soil].Physical.ParticleSizeClay[1:3] as Clay_0_30cm",
                "mean([Soil].Physical.ParticleSizeSand[1:3] as Sand_0_30cm",
                "mean([Soil].Physical.ParticleSizeSilt[1:3] as Silt_0_30cm",
                "mean([Soil].Organic.Carbon[1:3] as SOC_0_30cm",
                "",
                "//Weather",
                "sum of [Weather].Rain from [Clock].StartOfYear to [Clock].EndOfYear as AnnualRain",
                "sum of [Weather].Radn from [Clock].StartOfYear to [Clock].EndOfYear as AnnualRadn",
                "mean of [Weather].MaxT from [Clock].StartOfYear to [Clock].EndOfYear as AnnualMaxt",
                "mean of [Weather].MinT from [Clock].StartOfYear to [Clock].EndOfYear as AnnualMint",
                "mean of [Weather].MeanT from [Clock].StartOfYear to [Clock].EndOfYear as AnnualMeanT",
                "//april to sept covers most of the season across the state",
                "sum of [Weather].Rain from April-15 to Oct-15 as SeasonRain",
                "sum of [Weather].Radn from April-15 to Oct-15 as SeasonRadn",
                "mean of [Weather].MaxT from April-15 to Oct-15 as SeasonMaxt",
                "mean of [Weather].MinT from April-15 to Oct-15 as SeasonMint",
                "mean of [Weather].MeanT from April-15 to Oct-15 as SeasonMeanT",
                "//dry April and good stands, and rainfall/moderate temps during grain fill (June/early July), indicates a good season",
                "//april and early may covers most of planting season",
                "sum of [Weather].Rain from April-15 to May-31 as SowingSeasonRain",
                "sum of [Weather].Radn from April-15 to May-31 as SowingSeasonRadn",
                "mean of [Weather].MaxT from April-15 to May-31 as SowingSeasonMaxt",
                "mean of [Weather].MinT from April-15 to May-31 as SowingSeasonMint",
                "mean of [Weather].MeanT from April-15 to May-31 as SowingSeasonMeanT",
                "//jun and early july covers most of blooming/pod setting range",
                "sum of [Weather].Rain from Jun-1 to Jul-31 as BloomingSeasonRain",
                "sum of [Weather].Radn from Jun-1 to Jul-31  as BloomingSeasonRadn",
                "mean of [Weather].MaxT from Jun-1 to Jul-31  as BloomingSeasonMaxt",
                "mean of [Weather].MinT from Jun-1 to Jul-31  as BloomingSeasonMint",
                "mean of [Weather].MeanT from Jun-1 to Jul-31 as BloomingSeasonMeanT",
                "sum of [Weather].Rain from Jun-1 to Jun-30 as JuneRain",
                "sum of [Weather].Radn from Jun-1 to Jun-30 as JuneRadn",
                "mean of [Weather].MaxT from Jun-1 to Jun-30 as JuneMaxt",
                "mean of [Weather].MinT from Jun-1 to Jun-30 as JuneMint",
                "mean of [Weather].MeanT from Jun-1 to Jun-30 as JuneMeanT",
                "sum of [Weather].Rain from Jul-1 to Jul-31 as JulyRain",
                "sum of [Weather].Radn from Jul-1 to Jul-31 as JulyRadn",
                "mean of [Weather].MaxT from Jul-1 to Jul-31 as JulyMaxt",
                "mean of [Weather].MinT from Jul-1 to Jul-31 as JulyMint",
                "mean of [Weather].MeanT from Jul-1 to Jul-31 as JulyMeanT",
                "",
                "//System",
                "sum of ([Soil].SoilWater.Evaporation+[Soybean].Leaf.Transpiration) from [Soybean].Sowing to [Soybean].Harvesting as Crop_ET",
                "sum of [Soil].SoilWater.Eo from [Soybean].Sowing to [Soybean].Harvesting as Potential_Crop_ET",
                "mean of [Soybean].Leaf.Photosynthesis.FW.XValue from Jun-1 to Jul-15 as Silking_Supply_Demand_Ratio"
              ],
